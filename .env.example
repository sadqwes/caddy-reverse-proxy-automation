# Slack Incoming Webhook URL
SLACK_WEBHOOK_URL=

# Comma-separated list of systemd services to monitor
SERVICES=caddy.service,actions.runner.service

# Services that may be restarted automatically after a failure
AUTO_RESTART_SERVICES=caddy.service

# Directory for alert state files
STATE_DIR=/opt/alerts

# Optional host label used in Slack notifications
ALERT_HOSTNAME=proxy-host
